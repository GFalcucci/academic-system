<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.academic.system.controller.ClassRegistrationController"
      spacing="15"
      alignment="CENTER"
      style="-fx-background-color: #f4f4f4; -fx-padding: 30;">

    <Label text="🏫 Cadastro de Turma" 
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;">
        <font>
            <Font name="System Bold" size="22"/>
        </font>
    </Label>

    <Label text="Crie uma nova turma no sistema" 
           style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>

    <TextField fx:id="codeField" 
               promptText="Código da turma (ex: TURMA001)"
               prefWidth="300"
               style="-fx-font-size: 14px;"/>

    <TextField fx:id="nameField" 
               promptText="Nome da turma (ex: Matemática)"
               prefWidth="300"
               style="-fx-font-size: 14px;"/>

    <Button text="✅ Cadastrar Turma"
            onAction="#cadastrarTurma"
            prefWidth="300"
            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>

    <Label fx:id="mensagemLabel" 
           style="-fx-font-size: 14px;" 
           wrapText="true"/>

    <Button text="🔙 Voltar ao Menu"
            onAction="#voltarDashboard"
            prefWidth="300"
            style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>

</VBox>