<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.academic.system.controller.PersistenceReportController"
      alignment="CENTER"
      spacing="15"
      style="-fx-padding: 20;">

    <Label text="Relatório de Persistência"
           style="-fx-font-size: 22px; -fx-font-weight: bold;" />

    <TextArea fx:id="conteudoArea"
              prefHeight="400"
              prefWidth="700"
              editable="false"/>

    <Button text="Carregar JSON"
            onAction="#carregarJson"/>

    <Button text="Carregar XML"
            onAction="#carregarXml"/>

    <Button text="Voltar"
            onAction="#voltar"/>

</VBox>