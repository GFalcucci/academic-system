<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.academic.system.controller.ViewClassesController"
      spacing="12"
      alignment="CENTER"
      style="-fx-background-color: #f4f4f4; -fx-padding: 30;">

    <Label text="📚 Visualização de Turmas" 
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;">
        <font>
            <Font name="System Bold" size="22"/>
        </font>
    </Label>

    <Label text="Clique no botão abaixo para carregar todas as turmas" 
           style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>

    <Button text="🔄 Carregar Turmas"
            onAction="#carregarTurmas"
            prefWidth="300"
            style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>

    <TextArea fx:id="resultadoArea"
              prefHeight="400"
              prefWidth="600"
              style="-fx-font-family: 'Consolas', monospace; -fx-font-size: 13px; -fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-radius: 5;"/>

    <Button text="🔙 Voltar ao Menu"
            onAction="#voltarDashboard"
            prefWidth="300"
            style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>

</VBox>